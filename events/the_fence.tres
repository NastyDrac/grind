[ext_resource type="Script" uid="uid://chli81s5gxydu" path="res://Scripts/event_effect.gd" id="3_eff"]
[ext_resource type="Script" uid="uid://b3mi542wlp4b0" path="res://Scripts/EventEffects/effect_cost_gold.gd" id="4_gold"]
[ext_resource type="Script" uid="uid://cj25eabp5jigj" path="res://Scripts/EventEffects/effect_add_thingy.gd" id="5_thy"]
[ext_resource type="Script" uid="uid://b26b68w4tu72s" path="res://Scripts/leaky_purse.gd" id="7_wwtog"]

[sub_resource type="Resource" id="Res_sell"]
script = ExtResource("4_gold")
amount = 25
metadata/_custom_type_script = "uid://b3mi542wlp4b0"

[sub_resource type="Resource" id="Resource_u7v0o"]
script = ExtResource("5_thy")
random_thingy = true
metadata/_custom_type_script = "uid://cj25eabp5jigj"

[sub_resource type="Resource" id="Res_optA"]
script = ExtResource("1_opt")
option_text = "Sell your odds and ends."
result_text = "She turns your pocket-junk over once, names a price fair to the dollar, and counts it out without a flicker. Coin in hand, clutter gone."
effects = Array[ExtResource("3_eff")]([SubResource("Res_sell"), SubResource("Resource_u7v0o")])
metadata/_custom_type_script = "uid://ccujthovl5rv7"

[sub_resource type="Resource" id="Res_coin"]
script = ExtResource("4_gold")
amount = -100
metadata/_custom_type_script = "uid://b3mi542wlp4b0"

[sub_resource type="Resource" id="Resource_wg5o2"]
script = ExtResource("7_wwtog")
duration_combats = 2
condition_name = "Leaky Purse"
metadata/_custom_type_script = "uid://b26b68w4tu72s"

[sub_resource type="Resource" id="Res_leak"]
script = ExtResource("5_thy")
thingy = SubResource("Resource_wg5o2")
metadata/_custom_type_script = "uid://cj25eabp5jigj"

[sub_resource type="Resource" id="Res_optC"]
script = ExtResource("1_opt")
option_text = "Take the cursed coin."
result_text = "'It spends,' she allows, 'and then some. Comes back lighter every time — but that's the arrangement, take it or leave it.' Your purse is fat tonight. It will not stay that way."
effects = Array[ExtResource("3_eff")]([SubResource("Res_coin"), SubResource("Res_leak")])
metadata/_custom_type_script = "uid://ccujthovl5rv7"

[resource]
script = ExtResource("2_evt")
event_title = "The Fence"
event_description = "Behind a counter stacked with other people's heirlooms, a narrow woman appraises you the way she'd appraise a candlestick. 'I buy, I sell, and I ask no questions a body wouldn't care to answer,' she says. 'You've got the bearing of someone with goods to move and needs to meet. Let's see if we can't reach an understanding — mutually beneficial and entirely off the books.'"
options = Array[ExtResource("1_opt")]([SubResource("Res_optA"), SubResource("Res_optC")])
metadata/_custom_type_script = "uid://c8bk1dof3250"
