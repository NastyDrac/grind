[sub_resource type="Resource" id="Res_optC"]
script = ExtResource("1_opt")
option_text = "Mark the deck."
result_text = "He never sees you do it — or he's too well-mannered to say so. You leave with a fine prize tucked in your coat and one slick, worthless card you'll be cursing every time it surfaces at precisely the wrong moment."
effects = Array[ExtResource("3_eff")]([SubResource("Resource_02s57"), SubResource("Res_addc")])
metadata/_custom_type_script = "uid://ccujthovl5rv7"

[resource]
script = ExtResource("2_evt")
event_title = "The Card Sharp"
event_description = "A man with too many rings and not nearly enough tells is dealing to nobody in particular at a crooked little table. 'Friend,' he says without looking up, 'you have the look of a soul who appreciates a favorable arrangement. I deal in opportunity — the genuine, unvarnished article — and I find myself presently of a generous disposition. Pull up a chair. The house, on this rare and fleeting occasion, is feelin' charitable.'"
options = Array[ExtResource("1_opt")]([SubResource("Res_optA"), SubResource("Res_optB"), SubResource("Res_optC")])
metadata/_custom_type_script = "uid://c8bk1dof3250"
