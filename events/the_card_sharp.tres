[sub_resource type="Resource" id="Res_mod"]
script = ExtResource("4_mod")
modify_value = 1
random_stat = true
metadata/_custom_type_script = "uid://ckmlhw3dcvb0k"

[sub_resource type="Resource" id="Res_optA"]
script = ExtResource("1_opt")
option_text = "Watch the table a while."
result_text = "You say nothing and learn plenty — the flick of the wrist, the count of the deck, the tell he doesn't know he has. You walk off a shade sharper than you sat down."
effects = Array[ExtResource("3_eff")]([SubResource("Res_mod")])
metadata/_custom_type_script = "uid://ccujthovl5rv7"

[sub_resource type="Resource" id="Res_draft"]
script = ExtResource("5_draft")
metadata/_custom_type_script = "uid://cvilgkn5daoav"

[sub_resource type="Resource" id="Res_optB"]
script = ExtResource("1_opt")
option_text = "Buy into the game."
result_text = "Coin on the felt, and the cards come kinder. You leave the table with something worth keeping and the rare good sense to quit while you're ahead."
effects = Array[ExtResource("3_eff")]([SubResource("Res_draft")])
gold_cost = 40
metadata/_custom_type_script = "uid://ccujthovl5rv7"

