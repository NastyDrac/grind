[sub_resource type="Resource" id="Resource_jawdy"]
script = ExtResource("1_lsxmj")
option_text = "Kick it down"
result_text = "Well now… that thing’s makin’ a noise I don’t rightly trust, which means it’s probably got somethin’ worth havin’.
Give it a good boot. Worst case, it bites back."
effects = Array[ExtResource("3_eekrh")]([SubResource("Resource_3acma"), SubResource("Resource_2gjp5")])
