[sub_resource type="Resource" id="Resource_hsrr7"]
script = ExtResource("1_lsxmj")
option_text = "Strip it for parts"
result_text = "Now here’s a thought: locker’s busted, world’s busted, everything’s busted — might as well make the pieces useful.
Bit of wire here, hinge there… you’d be amazed what a clever hand can bolt onto a good swing."
effects = Array[ExtResource("3_eekrh")]([SubResource("Resource_o4fyf")])
metadata/_custom_type_script = "uid://ccujthovl5rv7"

[resource]
script = ExtResource("8_rgrht")
event_title = "Locker Room"
event_description = "You push into a busted‑up locker room — lights flickering like they’re fixin’ to give up, metal doors rattling in a draft that ain’t there. One locker’s humming like it swallowed something it shouldn’t."
options = Array[ExtResource("1_lsxmj")]([SubResource("Resource_jawdy"), SubResource("Resource_ruacm"), SubResource("Resource_hsrr7")])
metadata/_custom_type_script = "uid://c8bk1dof3250"
