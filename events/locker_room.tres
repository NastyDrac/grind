[sub_resource type="Resource" id="Resource_ruacm"]
script = ExtResource("1_lsxmj")
option_text = "Take a gentle peak"
result_text = "You could go in soft‑like, ease the door open, see what fortune left behind.
Course, that’s how folks end up with surprises they didn’t order."
