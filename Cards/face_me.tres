[gd_resource type="Resource" script_class="CardData" load_steps=10 format=3 uid="uid://ckn1ghttaunt0"]

[ext_resource type="Script" uid="uid://dhxff5egnsgrv" path="res://Scripts/action.gd" id="1_action"]
[ext_resource type="Script" uid="uid://0gsjrx47no8b" path="res://Scripts/card_data.gd" id="2_carddata"]
[ext_resource type="Script" uid="uid://cgrxhw8vqenhu" path="res://Scripts/ValueCalculator.gd" id="3_calc"]
[ext_resource type="Script" uid="uid://c3g4jmcp7xiqk" path="res://Scripts/pushpull_action.gd" id="4_pushpull"]
[ext_resource type="Script" uid="uid://px415e6h6tao" path="res://Scripts/block_action.gd" id="5_block"]

[sub_resource type="Resource" id="Calc_0_dist"]
script = ExtResource("3_calc")
formula = "-2"
metadata/_custom_type_script = "uid://cgrxhw8vqenhu"

[sub_resource type="Resource" id="Act_0"]
script = ExtResource("4_pushpull")
distance_calculator = SubResource("Calc_0_dist")
target_type = 1
animation_type = 4
metadata/_custom_type_script = "uid://c3g4jmcp7xiqk"

[sub_resource type="Resource" id="Calc_1_blk"]
