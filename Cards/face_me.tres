formula = "guts"
metadata/_custom_type_script = "uid://cgrxhw8vqenhu"

[sub_resource type="Resource" id="Act_1"]
script = ExtResource("5_block")
block_calculator = SubResource("Calc_1_blk")
target_type = 4
metadata/_custom_type_script = "uid://px415e6h6tao"

[resource]
script = ExtResource("2_carddata")
card_name = "Face Me!"
type = 1
actions = Array[ExtResource("1_action")]([SubResource("Act_0"), SubResource("Act_1")])
metadata/_custom_type_script = "uid://0gsjrx47no8b"
