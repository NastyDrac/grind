[gd_resource type="Resource" script_class="CardData" load_steps=10 format=3 uid="uid://cdrftsnap001"]

[ext_resource type="Script" uid="uid://dhxff5egnsgrv" path="res://Scripts/action.gd" id="1_action"]
[ext_resource type="Script" uid="uid://0gsjrx47no8b" path="res://Scripts/card_data.gd" id="2_carddata"]
[ext_resource type="Script" uid="uid://clvjn77csx1a0" path="res://Scripts/AttackAction.gd" id="3_attack"]
[ext_resource type="Script" uid="uid://cgrxhw8vqenhu" path="res://Scripts/ValueCalculator.gd" id="4_calc"]
[ext_resource type="Script" path="res://Scripts/draw_action.gd" id="5_draw"]

[sub_resource type="Resource" id="Calc_dmg"]
script = ExtResource("4_calc")
formula = "hustle+3"
metadata/_custom_type_script = "uid://cgrxhw8vqenhu"

[sub_resource type="Resource" id="Act_attack"]
script = ExtResource("3_attack")
damage_calculator = SubResource("Calc_dmg")
max_range = 3
animation_type = 1
metadata/_custom_type_script = "uid://clvjn77csx1a0"

[sub_resource type="Resource" id="Calc_draw"]
script = ExtResource("4_calc")
formula = "1"
metadata/_custom_type_script = "uid://cgrxhw8vqenhu"

[sub_resource type="Resource" id="Act_draw"]
script = ExtResource("5_draw")
card_count_calculator = SubResource("Calc_draw")
target_type = 4
metadata/_custom_type_script = "uid://cgrxhw8vqenhu"

[resource]
script = ExtResource("2_carddata")
card_name = "Snap Shot"
card_cost = 1
rarity = 0
actions = Array[ExtResource("1_action")]([SubResource("Act_attack"), SubResource("Act_draw")])
metadata/_custom_type_script = "uid://0gsjrx47no8b"
